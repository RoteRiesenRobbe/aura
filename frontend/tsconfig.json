{
	"compilerOptions": {
		"outDir": "./dist/",
		"sourceMap": true,
//		"noImplicitAny": true,
//		"module": "commonjs", // TODO replace with es6 to enable proper tree-shaking
		"target": "es5",
		"downlevelIteration": true,
		"alwaysStrict": true,
		"lib": [
			"es2017",
			"dom",
			"dom.iterable"
		],
		"types": [
			"webpack-env"
		],
		"moduleResolution": "Node",
		"esModuleInterop": true,
		"baseUrl": ".",
		"paths": {
			"flatbuffers": ["./node_modules/flatbuffers"]
		},
	},
	"include": [
		"./src/index.ts",
      "./src/old-structure/**/*"
	]
}
